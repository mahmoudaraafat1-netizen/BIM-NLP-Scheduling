      "Description": "Creates a string",
      "InputValue": "Area"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# المدخلات: قائمة المواد (Materials)\r\nmaterials = IN[0]  # القائمة المدخلة (Material.Name)\r\n\r\n# الكلمة المفتاحية لتصفية المواد\r\nkeyword = \"Plaster\"\r\n\r\n# تصفية المواد بناءً على الكلمة المفتاحية\r\nfiltered_materials = [\r\n    material for material in materials\r\n    if keyword.lower() in str(material).lower()\r\n]\r\n\r\n# إخراج المواد المصفاة\r\nOUT = filtered_materials\r\n",
      "Engine": "IronPython2",
      "EngineName": "IronPython2",
      "VariableInputPorts": true,
      "Id": "cefe29337c644146a52285701c279a1a",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "4ae4cffd982649a793b16995d3cc3493",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "c296d0b652a447f0b7014545516b69db",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# المدخلات: الجدول الناتج (List.Transpose الناتج)\r\ndata = IN[0]  # الجدول (كل صف يمثل [Level, Material, Area])\r\n\r\n# تصفية الصفوف التي تحتوي على قيم null في العمود الثاني (Material)\r\nfiltered_data = []\r\nfor row in data:\r\n    if row[1] is not None and row[1] != \"\":  # التحقق أن المادة ليست null أو فارغة\r\n        filtered_data.append(row)\r\n\r\n# إخراج الصفوف التي تحتوي فقط على مواد\r\nOUT = filtered_data\r\n",
      "Engine": "IronPython2",
      "EngineName": "IronPython2",
      "VariableInputPorts": true,
      "Id": "7db8d2283fc5457e95e14ca8b22812da",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "6b4170ed3ef649969bf751a4eda799b2",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "f2c5458558354994b14bfe63de9cdccf",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
