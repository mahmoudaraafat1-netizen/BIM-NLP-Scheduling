    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python 3.x (PRODUCTION - Shuttering Area only)\r\nimport clr, math\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nFT_TO_M = 0.3048\r\n\r\ndef get_param(el, names):\r\n    # instance then type\r\n    for n in names:\r\n        p = el.LookupParameter(n)\r\n        if p and p.StorageType != StorageType.String:\r\n            try: return p.AsDouble()\r\n            except: pass\r\n    s = getattr(el, \"Symbol\", None)\r\n    if s:\r\n        for n in names:\r\n            p = s.LookupParameter(n)\r\n            if p and p.StorageType != StorageType.String:\r\n                try: return p.AsDouble()\r\n                except: pass\r\n    return None\r\n\r\ndef any_3d(doc):\r\n    for v in FilteredElementCollector(doc).OfClass(View3D):\r\n        if not v.IsTemplate: return v\r\n    return None\r\n\r\ndef height_ft(el, v3d):\r\n    h = get_param(el, [\"Unconnected Height\",\"Height\",\"ارتفاع\"])\r\n    if h and h>0: return h\r\n    try:\r\n        bl = el.LookupParameter(\"Base Level\")\r\n        tl = el.LookupParameter(\"Top Level\")\r\n        b_off = get_param(el, [\"Base Offset\",\"Base Offset Value\"]) or 0.0\r\n        t_off = get_param(el, [\"Top Offset\",\"Top Offset Value\"]) or 0.0\r\n        if bl and tl:\r\n            b = doc.GetElement(bl.AsElementId()); t = doc.GetElement(tl.AsElementId())\r\n            if b and t:\r\n                val = (t.Elevation + t_off) - (b.Elevation + b_off)\r\n                if val>0: return val\r\n    except: pass\r\n    try:\r\n        bb = el.get_BoundingBox(v3d) if v3d else el.get_BoundingBox(None)\r\n        if bb:\r\n            dz = bb.Max.Z - bb.Min.Z\r\n            if dz>0: return dz\r\n    except: pass\r\n    return 0.0\r\n\r\ndef perimeter_ft(el, v3d):\r\n    b = get_param(el, [\"b\",\"B\",\"Width\",\"عرض\"])\r\n    d = get_param(el, [\"h\",\"H\",\"Depth\",\"عمق\"])\r\n    if b and d and b>0 and d>0: return 2.0*(b+d)\r\n    dia = get_param(el, [\"Diameter\",\"D\",\"قطر\"])\r\n    if dia and dia>0: return math.pi*dia\r\n    try:\r\n        bb = el.get_BoundingBox(v3d) if v3d else el.get_BoundingBox(None)\r\n        if bb:\r\n            dx = bb.Max.X - bb.Min.X\r\n            dy = bb.Max.Y - bb.Min.Y\r\n            if dx>0 and dy>0: return 2.0*(dx+dy)\r\n    except: pass\r\n    return 0.0\r\n\r\n# MAIN\r\nels_in = IN[0]\r\nif not isinstance(els_in, list): els_in = [els_in]\r\nels = [UnwrapElement(e) for e in els_in]\r\nv3d = any_3d(doc)\r\n\r\nareas = []\r\nfor el in els:\r\n    per_ft = perimeter_ft(el, v3d)\r\n    h_ft   = height_ft(el, v3d)\r\n    areas.append(round((per_ft*FT_TO_M)*(h_ft*FT_TO_M), 3) if per_ft>0 and h_ft>0 else 0.0)\r\n\r\nOUT = areas\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "49f52e50c07f4c2eb91126ecfebf5606",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "fb3d8bb1575844579d903eba67777f40",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "c82956d1200146cfbe3fb4963c0707ef",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Dynamo Python 3.x - Shuttering Area for Foundations\r\nimport clr, math\r\n\r\n# Revit API & Dynamo references\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\nclr.AddReference(\"RevitServices\")\r\nfrom RevitServices.Persistence import DocumentManager\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nFT_TO_M = 0.3048\r\n\r\ndef get_param(el, names):\r\n    for n in names:\r\n        p = el.LookupParameter(n)\r\n        if p and p.StorageType != StorageType.String:\r\n            try:\r\n                return p.AsDouble()\r\n            except:\r\n                pass\r\n    s = getattr(el, \"Symbol\", None)\r\n    if s:\r\n        for n in names:\r\n            p = s.LookupParameter(n)\r\n            if p and p.StorageType != StorageType.String:\r\n                try:\r\n                    return p.AsDouble()\r\n                except:\r\n                    pass\r\n    return None\r\n\r\ndef any_3d(doc):\r\n    for v in FilteredElementCollector(doc).OfClass(View3D):\r\n        if not v.IsTemplate:\r\n            return v\r\n    return None\r\n\r\ndef foundation_shutter_m2(el, v3d, sides=4):\r\n    # Dimensions\r\n    b = get_param(el, [\"b\",\"B\",\"Width\"])\r\n    d = get_param(el, [\"h\",\"H\",\"Depth\",\"Length\"])\r\n    h = get_param(el, [\"Thickness\",\"Foundation Thickness\",\"Unconnected Height\",\"Height\"])\r\n    if not h:\r\n        try:\r\n            bb = el.get_BoundingBox(v3d) if v3d else el.get_BoundingBox(None)\r\n            h = bb.Max.Z - bb.Min.Z\r\n        except:\r\n            h = 0.0\r\n    \r\n    if not b or not d or not h:\r\n        return 0.0\r\n    \r\n    # Convert to meters\r\n    b_m, d_m, h_m = b*FT_TO_M, d*FT_TO_M, h*FT_TO_M\r\n\r\n    # Perimeter depends on sides (4 or 3)\r\n    per_m = (2*b_m + 2*d_m) * (sides/4.0)\r\n    area_m2 = per_m * h_m\r\n    return round(area_m2, 3)\r\n\r\n# ---- MAIN ----\r\nels_in = IN[0]\r\nif not isinstance(els_in, list): els_in = [els_in]\r\nels = [UnwrapElement(e) for e in els_in]\r\nv3d = any_3d(doc)\r\n\r\n# Set sides = 4 (كل الجوانب)، ممكن تغيّرها لـ 3 لو القاعدة ملتصقة بجانب\r\nOUT = [foundation_shutter_m2(e, v3d, sides=4) for e in els]\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "caf86edd9ef54c92ba38a56f01448795",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "f2ee110a3a164fcd9d20b76a03cdc41b",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "dbfd8b37952b48a085f039e242f0dad6",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
