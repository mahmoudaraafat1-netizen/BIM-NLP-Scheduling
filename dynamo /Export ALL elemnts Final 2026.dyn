      {
        "Id": "cefe29337c644146a52285701c279a1a",
        "Name": "# المدخلات: قائمة المواد (Materials)\r\nmaterials = IN[0]  # القائمة المدخلة (أسماء المواد)\r\n\r\n# الكلمات المفتاحية للبحث\r\nkeywords = [\"CMU\", \"Brick\", \"Block\"]\r\n\r\n# تصفية المواد بناءً على الكلمات المفتاحية\r\nfiltered_materials = []\r\nfor material in materials:\r\n    # تحقق إذا كانت أي كلمة مفتاحية موجودة في اسم المادة\r\n    if any(keyword.lower() in str(material).lower() for keyword in keywords):\r\n        filtered_materials.append(material)\r\n\r\n# إخراج المواد التي تطابق الشرط\r\nOUT = filtered_materials\r\n",
        "IsSetAsInput": false,
        "IsSetAsOutput": false,
        "Excluded": false,
        "ShowGeometry": true,
        "X": -456.20674278424144,
        "Y": 2014.4274083711884
      },
      {
        "Id": "7db8d2283fc5457e95e14ca8b22812da",
        "Name": "# المدخلات: الجدول الناتج (المواد، الأدوار، المساحات)\r\ndata = IN[0]  # الجدول (List.Transpose الناتج)\r\n\r\n# تصفية الصفوف التي تحتوي على قيم null\r\nfiltered_data = []\r\nfor row in data:\r\n    if row[0] is not None:  # تحقق إذا كانت المادة (column 0) ليست null\r\n        filtered_data.append(row)\r\n\r\n# إخراج الصفوف المصفاة\r\nOUT = filtered_data\r\n",
        "IsSetAsInput": false,
        "IsSetAsOutput": false,
        "Excluded": false,
        "ShowGeometry": true,
        "X": 976.38763523495481,
        "Y": 1819.8340935240187
